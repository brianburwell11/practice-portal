---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('docs')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li a {
				display: block;
				padding: 1.25rem 1.5rem;
				border: 1px solid rgb(var(--gray-light), 0.5);
				border-radius: 8px;
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li a:hover {
				border-color: rgb(var(--accent));
				box-shadow: var(--box-shadow);
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.description {
				margin: 0.5rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				line-height: 1.4;
			}
			.meta {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin: 0.5rem 0 0;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}
			.tag {
				display: inline-block;
				padding: 0.15rem 0.5rem;
				border-radius: 9999px;
				background: rgb(var(--gray-light), 0.3);
				color: rgb(var(--gray));
				font-size: 0.75rem;
			}
			ul li a:hover .title {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/docs/${post.id}/`}
								data-search={[post.data.title, post.data.description, ...(post.data.tags ?? []), post.body].join(' ').toLowerCase()}>
									<h4 class="title">{post.data.title}</h4>
									{post.data.description && <p class="description">{post.data.description}</p>}
									<div class="meta">
										<span class="date"><FormattedDate date={post.data.pubDate} /></span>
										{post.data.tags?.map((tag) => <span class="tag">{tag}</span>)}
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			const input = document.getElementById('docs-search') as HTMLInputElement;
			const items = document.querySelectorAll<HTMLLIElement>('section ul li');
			input?.addEventListener('input', () => {
				const terms = input.value.toLowerCase().split(/\s+/).filter(Boolean);
				items.forEach((li) => {
					const text = li.querySelector('a')?.dataset.search ?? '';
					const match = terms.length === 0 || terms.every((t) => text.includes(t));
					li.style.display = match ? '' : 'none';
				});
			});
		</script>
	</body>
</html>
